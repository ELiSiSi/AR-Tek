extends base

block content

  //- ═══════════════════════════════════════════
  //- TOP CONTACT BAR
  //- ═══════════════════════════════════════════
  .top-contact-bar
    .container
      a.top-contact-link(
        href="https://wa.me/201063777925"
        target="_blank"
        rel="noopener noreferrer"
      )
        span للاستفسار: 01063777925
        svg(width="18" height="18" viewBox="0 0 24 24" fill="currentColor")
          path(d="M20.52 3.48A11.86 11.86 0 0 0 12.07 0C5.5 0 .16 5.34.16 11.91c0 2.1.55 4.15 1.6 5.96L0 24l6.3-1.65a11.9 11.9 0 0 0 5.77 1.47h.01c6.57 0 11.91-5.34 11.91-11.91 0-3.18-1.24-6.17-3.47-8.43zM12.08 21.8a9.9 9.9 0 0 1-5.05-1.39l-.36-.21-3.74.98 1-3.64-.24-.37a9.88 9.88 0 0 1-1.52-5.26c0-5.46 4.45-9.91 9.91-9.91 2.65 0 5.14 1.03 7.01 2.9a9.84 9.84 0 0 1 2.9 7c0 5.47-4.45 9.91-9.91 9.91zm5.43-7.43c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.47-.88-.79-1.47-1.76-1.64-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.03-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.08-.79.37-.27.3-1.04 1.01-1.04 2.47s1.07 2.87 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.31 1.27.5 1.7.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.41.25-.7.25-1.29.17-1.42-.08-.13-.28-.2-.58-.35z")
  //- ═══════════════════════════════════════════
  //- HERO SECTION
  //- ═══════════════════════════════════════════
  section.hero
    .hero-bg-grid(aria-hidden="true")
    .hero-orb.hero-orb--1(aria-hidden="true")
    .hero-orb.hero-orb--2(aria-hidden="true")
    .hero-scan-line(aria-hidden="true")

    .container
      .hero-inner
        .hero-content(data-reveal)
          .hero-eyebrow
            span.eyebrow-dot(aria-hidden="true")
            span.eyebrow-text مرحباً بك في AR Tek
            span.eyebrow-line(aria-hidden="true")
            span.eyebrow-en Welcome to AR Tek

          h1.hero-title
            span.hero-title--top تقنية
            span.hero-title--grad بلا
            span.hero-title--outline حدود

          p.hero-description
            | إلكترونيات شخصية بمستوى عالمي. سماعات لا تُضاهى، ساعات تُرافقك، وأجهزة تصفيف احترافية.
            br
            span.hero-desc-en Personal electronics at a global standard. Discover the difference.

          .hero-actions
            a.btn.btn-primary(href="/products") تسوق الآن
            a.btn.btn-outline(href="/offers") العروض الحالية
        .hero-visual(data-reveal data-delay="200")
          .hero-card-stack
            //- Main floating product card
            .hcard.hcard--main
              .hcard-glow(aria-hidden="true")
              .hcard-top
                .hcard-tag
                  span.tag.tag-new جديد · NEW
                .hcard-badge
                  svg(width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
                    polygon(points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2")
                  span 4.9
              .hcard-visual
                .hcard-icon-wrap
                  svg.hcard-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true")
                    path(d="M3 18v-6a9 9 0 0118 0v6")
                    path(d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z")
                .hcard-pulse(aria-hidden="true")
              .hcard-info
                p.hcard-name سماعة AR Pro X1
                p.hcard-name-en Wireless ANC Headphones
                .hcard-price-row

              a.btn.btn-primary(href="/products") عرض المنتاجات

            //- Floating chips
            .chip.chip--1(aria-hidden="true")
              .chip-icon
                svg(width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                  path(d="M22 11.08V12a10 10 0 11-5.93-9.14")
                  polyline(points="22 4 12 14.01 9 11.01")
              .chip-content
                span.chip-label Noise Cancel
                span.chip-val ANC Pro
            .chip.chip--2(aria-hidden="true")
              .chip-icon
                svg(width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                  path(d="M13 2L3 14h9l-1 8 10-12h-9l1-8z")
              .chip-content
                span.chip-label Battery
                span.chip-val 40 Hours
            .chip.chip--3(aria-hidden="true")
              .chip-icon
                svg(width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                  path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
              .chip-content
                span.chip-label Warranty
                span.chip-val 2 Years

            //- Mini cards in background
            .hcard.hcard--sm.hcard--left
              .hcard-sm-icon
                svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
                  rect(x="5" y="2" width="14" height="20" rx="2")
                  circle(cx="12" cy="17" r="1")
                  path(d="M9 6h6")
              p.hcard-sm-name ساعة Smart Pro
              p.hcard-sm-price 899 جنيه

            .hcard.hcard--sm.hcard--right
              .hcard-sm-icon
                svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
                  path(d="M12 2a3 3 0 013 3v7a3 3 0 01-6 0V5a3 3 0 013-3z")
                  path(d="M19 10v2a7 7 0 01-14 0v-2")
                  line(x1="12" y1="19" x2="12" y2="22")
                  line(x1="8" y1="22" x2="16" y2="22")
              p.hcard-sm-name شالش Pro
              p.hcard-sm-price 649 جنيه

  //- ═══════════════════════════════════════════
  //- MARQUEE / TICKER
  //- ═══════════════════════════════════════════
  .marquee-section(aria-hidden="true")
    .marquee-track
      .marquee-inner
        - var items = ['سماعات · Audio', 'ساعات ذكية · Wearables', 'شالش · Shavers', 'تصفيف · Styling', 'إكسسوارات · Accessories', 'عروض · Offers', 'توصيل سريع · Fast Delivery', 'ضمان · Warranty']
        each item in [...items, ...items]
          span.marquee-item
            span.marquee-dot(aria-hidden="true")
            | #{item}

