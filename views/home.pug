  //- ═══════════════════════════════════════════
  section.section.why-section
    .container
      .section-header(data-reveal)
        .section-label لماذا AR Tek · Why Us
        h2.section-title لماذا تختارنا؟
        p.section-subtitle Because you deserve technology that works as hard as you do.

      .why-grid
        .why-card(data-reveal)
          .why-icon-wrap
            svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
          h3.why-title منتجاتنا تأتي مع ضمان
          p.why-en  Warranty
          p.why-desc جميع منتجاتنا تأتي مع ضمان كامل   وخدمة ما بعد البيع.

        .why-card(data-reveal data-delay="100")
          .why-icon-wrap
            svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              circle(cx="12" cy="12" r="10")
              polyline(points="12 6 12 12 16 14")
          h3.why-title توصيل سريع
          p.why-en  Delivery
          p.why-desc نوصل لباب بيتك في أقل من 24 ساعة في جميع أنحاء مصر.

        .why-card(data-reveal data-delay="200")
          .why-icon-wrap
            svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              path(d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z")
          h3.why-title منتجات أصلية 100%
          p.why-en 100% Authentic
          p.why-desc نضمن لك أن كل منتج أصلي ومعتمد من الشركة المصنعة.

        .why-card(data-reveal data-delay="300")
          .why-icon-wrap
            svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true")
              path(d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z")
          h3.why-title دعم فني 7/24
          p.why-en 24/7 Support
          p.why-desc فريق الدعم الفني متاح على مدار الساعة لمساعدتك في أي وقت.

