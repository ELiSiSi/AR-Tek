  //- ═══════════════════════════════════════════
  //- FEATURED PRODUCTS
  //- ═══════════════════════════════════════════
  section.section.products-section
    .container
      .section-header(data-reveal)
        .section-label منتجات مختارة · Featured
        h2.section-title الأكثر طلباً
        p.section-subtitle Our best-selling personal electronics, handpicked for you.
      .section-header-action(data-reveal)
        a.btn.btn-ghost(href="/products") كل المنتجات · View All
          svg(width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
            path(d="M5 12h14M12 5l7 7-7 7")

      .products-grid

        //- Product 1
        .product-card(data-reveal)
          .product-card-img
            .product-img-placeholder
              svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true")
                path(d="M3 18v-6a9 9 0 0118 0v6")
                path(d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z")
            .product-badges
              span.tag.tag-new جديد
          .product-card-body
            p.product-cat سماعات · Audio
            h3.product-name سماعة AR Pro X1
            p.product-name-en Wireless ANC · 40H Battery
            .product-rating
              each star in [1,2,3,4,5]
                svg(width="12" height="12" viewBox="0 0 24 24" fill="#49E0D3" stroke="none" aria-hidden="true")
                  polygon(points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2")
              span.rating-count (48)
            .product-price-row
              span.product-price 1,299 جنيه
              span.product-price-old 1,799 جنيه
            button.btn.btn-primary.btn-full(type="button") أضف للسلة

        //- Product 2
        .product-card(data-reveal data-delay="100")
          .product-card-img
            .product-img-placeholder
              svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true")
                rect(x="5" y="2" width="14" height="20" rx="2")
                circle(cx="12" cy="17" r="1")
                path(d="M9 6h6")
            .product-badges
              span.tag.tag-sale خصم 30%
          .product-card-body
            p.product-cat ساعات ذكية · Wearables
            h3.product-name AR Watch Ultra S2
            p.product-name-en Health Monitor · GPS · AMOLED
            .product-rating
              each star in [1,2,3,4,5]
                svg(width="12" height="12" viewBox="0 0 24 24" fill="#49E0D3" stroke="none" aria-hidden="true")
                  polygon(points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2")
              span.rating-count (63)
            .product-price-row
              span.product-price 899 جنيه
              span.product-price-old 1,299 جنيه
            button.btn.btn-primary.btn-full(type="button") أضف للسلة

        //- Product 3
        .product-card(data-reveal data-delay="200")
