  //- CATEGORIES SECTION
  //- ═══════════════════════════════════════════
  section.section.cats-section
    .container
      .section-header(data-reveal)
        .section-label فئاتنا · Categories
        h2.section-title كل اللي محتاجه في مكان واحد
        p.section-subtitle All your personal tech needs — audio, wearables, and grooming under one roof.

      .cats-grid
        //- Audio - Large card
        a.cat-card.cat-card--large(href="/products" data-reveal)
          .cat-card-bg(aria-hidden="true")
          .cat-card-icon-wrap
            svg.cat-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-label="سماعات")
              path(d="M3 18v-6a9 9 0 0118 0v6")
              path(d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z")
          .cat-card-content
            .cat-card-tag +12 منتج
            h3.cat-card-name سماعات
            p.cat-card-en Audio · Headphones
            p.cat-card-desc سماعات لاسلكية، ANC، وأكثر
          .cat-card-arrow
            svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
              path(d="M5 12h14M12 5l7 7-7 7")

        //- Wearables
        a.cat-card(href="/products" data-reveal data-delay="100")
          .cat-card-bg(aria-hidden="true")
          .cat-card-icon-wrap
            svg.cat-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-label="ساعات ذكية")
              rect(x="5" y="2" width="14" height="20" rx="2")
              circle(cx="12" cy="17" r="1")
              path(d="M9 6h6")
          .cat-card-content
            .cat-card-tag +8 منتج
            h3.cat-card-name ساعات ذكية
            p.cat-card-en Wearables · Smartwatch
            p.cat-card-desc تتبع صحتك وأنشطتك
          .cat-card-arrow
            svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
              path(d="M5 12h14M12 5l7 7-7 7")

        //- Grooming
        //- a.cat-card(href="/products/grooming" data-reveal data-delay="200")
        //-   .cat-card-bg(aria-hidden="true")
        //-   .cat-card-icon-wrap
        //-     svg.cat-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-label="حلاقة وتصفيف")
        //-       path(d="M6 3a3 3 0 016 0v11a3 3 0 01-6 0V3z")
        //-       path(d="M9 14v7")
        //-       path(d="M3 10h6")
        //-       path(d="M15 7h6")
        //-       path(d="M15 11h6")
        //-       path(d="M15 15h3")
        //-   .cat-card-content
        //-     .cat-card-tag +15 منتج
        //-     h3.cat-card-name حلاقة وتصفيف
        //-     p.cat-card-en Grooming · Styling
        //-     p.cat-card-desc شالش وأجهزة تصفيف شعر احترافية
        //-   .cat-card-arrow
        //-     svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
        //-       path(d="M5 12h14M12 5l7 7-7 7")

        //- Accessories
        a.cat-card(href="/products" data-reveal data-delay="300")
          .cat-card-bg(aria-hidden="true")
          .cat-card-icon-wrap
            svg.cat-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-label="إكسسوارات")
              polygon(points="13 2 3 14 12 14 11 22 21 10 12 10 13 2")
          .cat-card-content
            .cat-card-tag +20 منتج
            h3.cat-card-name إكسسوارات
            p.cat-card-en Accessories · Add-ons
            p.cat-card-desc كل ما يكمل تجربتك التقنية
          .cat-card-arrow
            svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true")
              path(d="M5 12h14M12 5l7 7-7 7")


