extends base

block content
  - const safeStats = (typeof stats === 'object' && stats) ? stats : {}

  .stats-grid
    .stat-card
      .stat-icon
        i.fa-solid.fa-basket-shopping
      .stat-content
        span.stat-label إجمالي الطلبات
        strong.stat-value= safeStats.totalOrders || 0
        small.stat-hint كل الطلبات داخل النظام

    .stat-card
      .stat-icon
        i.fa-solid.fa-clock
      .stat-content
        span.stat-label الطلبات قيد الانتظار
        strong.stat-value= safeStats.pendingOrders || 0
        small.stat-hint لم يتم تنفيذها بعد

    .stat-card
      .stat-icon
        i.fa-solid.fa-circle-check
      .stat-content
        span.stat-label الطلبات المكتملة
        strong.stat-value= safeStats.doneOrders || 0
        small.stat-hint تم تسليمها بنجاح

    .stat-card
      .stat-icon
        i.fa-solid.fa-money-bill-trend-up
      .stat-content
        span.stat-label إجمالي الإيرادات
        strong.stat-value= (safeStats.totalRevenue || 0) + ' ج.م'
        small.stat-hint من الطلبات المكتملة

  // ================= QUICK ACTIONS =================
  .quick-grid
    a.quick-card(href="/admin/orders")
      i.fa-solid.fa-basket-shopping
      h3 إدارة الطلبات
      p عرض وتعديل حالة الطلبات

    a.quick-card(href="/admin/products")
      i.fa-solid.fa-box
      h3 إدارة المنتجات
      p إضافة وتعديل المنتجات

    a.quick-card(href="/admin/offers")
      i.fa-solid.fa-tags
      h3 إدارة العروض
      p إنشاء وإدارة الخصومات

    a.quick-card(href="/admin/cashier/orders")
      i.fa-solid.fa-cash-register
      h3 الكاشير
      p تنفيذ الطلبات بدون حذف

